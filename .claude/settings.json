{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit:*)",
            "command": "cargo fmt --all",
            "timeout": 30,
            "statusMessage": "Running cargo fmt --all..."
          }
        ]
      }
    ]
  }
}
